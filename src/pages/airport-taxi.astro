---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CallBand from "../components/CallBand.astro";
import { localBusinessSchema } from "../components/LocalBusinessSchema";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLocaleContent, type Locale } from "../site.config";

interface Props {
  locale?: Locale;
}

const locale: Locale = Astro.props.locale ?? "en";
const { business, airportPage, nav } = getLocaleContent(locale);
const path = "/airport-taxi/";
---

<BaseLayout title={airportPage.title} description={airportPage.description} canonicalPath={path} locale={locale} schema={localBusinessSchema(path, locale)}>
  <Header locale={locale} currentPath={path} />
  <main class="page-main">
    <section class="page-hero">
      <p class="eyebrow">{airportPage.eyebrow}</p>
      <h1>{airportPage.heading}</h1>
      <p>{airportPage.description}</p>
      <a class="button" href={`tel:${business.phone}`}>{nav.call} {business.displayPhone}</a>
    </section>
    <section class="section detail-list">
      <article>
        <h2>{airportPage.departures}</h2>
        <p>{airportPage.departuresText}</p>
      </article>
      <article>
        <h2>{airportPage.arrivals}</h2>
        <p>{airportPage.arrivalsText}</p>
      </article>
      <article>
        <h2>{airportPage.prebooking}</h2>
        <p>{airportPage.prebookingText}</p>
      </article>
    </section>
    <CallBand locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
