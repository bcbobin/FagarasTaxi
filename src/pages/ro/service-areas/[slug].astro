---
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import CallBand from "../../../components/CallBand.astro";
import { localBusinessSchema } from "../../../components/LocalBusinessSchema";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getLocaleContent, type Locale } from "../../../site.config";

interface Props {
  locale?: Locale;
  area: ReturnType<typeof getLocaleContent>["business"]["serviceAreas"][number];
}

export function getStaticPaths() {
  const { business } = getLocaleContent("ro");
  return business.serviceAreas.map((area) => ({
    params: { slug: area.slug },
    props: { area, locale: "ro" satisfies Locale }
  }));
}

const locale: Locale = Astro.props.locale ?? "ro";
const { business, areaPage, nav } = getLocaleContent(locale);
const { area } = Astro.props;
const title = `${areaPage.titlePrefix} ${area.name} | ${business.name}`;
const description = `${area.description} ${areaPage.descriptionSuffix}`;
const path = `/service-areas/${area.slug}/`;
---

<BaseLayout title={title} description={description} canonicalPath={path} locale={locale} schema={localBusinessSchema(path, locale)}>
  <Header locale={locale} currentPath={path} />
  <main class="page-main">
    <section class="page-hero">
      <p class="eyebrow">{areaPage.eyebrow}</p>
      <h1>{areaPage.headingPrefix} {area.name}</h1>
      <p>{description}</p>
      <a class="button" href={`tel:${business.phone}`}>{nav.call} {business.displayPhone}</a>
    </section>
    <section class="section detail-list">
      <article>
        <h2>{areaPage.localPickups}</h2>
        <p>{areaPage.localPickupsText} {area.name}.</p>
      </article>
      <article>
        <h2>{areaPage.airportTransfers}</h2>
        <p>{areaPage.airportTransfersText} {area.name}.</p>
      </article>
      <article>
        <h2>{areaPage.prebookedRides}</h2>
        <p>{areaPage.prebookedRidesText}</p>
      </article>
    </section>
    <CallBand locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
