---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import CallBand from "../../components/CallBand.astro";
import { localBusinessSchema } from "../../components/LocalBusinessSchema";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLocaleContent, localizedPath, type Locale } from "../../site.config";

interface Props {
  locale?: Locale;
}

const locale: Locale = Astro.props.locale ?? "en";
const { business, areasPage } = getLocaleContent(locale);
const path = "/service-areas/";
---

<BaseLayout title={areasPage.title} description={areasPage.description} canonicalPath={path} locale={locale} schema={localBusinessSchema(path, locale)}>
  <Header locale={locale} currentPath={path} />
  <main class="page-main">
    <section class="page-hero">
      <p class="eyebrow">{areasPage.eyebrow}</p>
      <h1>{areasPage.heading}</h1>
      <p>{areasPage.description}</p>
    </section>
    <section class="section">
      <div class="card-grid">
        {business.serviceAreas.map((area) => (
          <article class="service-card">
            <h2>{area.name}</h2>
            <p>{area.description}</p>
            <a class="text-link" href={localizedPath(locale, `/service-areas/${area.slug}/`)}>{areasPage.linkPrefix} {area.name}</a>
          </article>
        ))}
      </div>
    </section>
    <CallBand locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
