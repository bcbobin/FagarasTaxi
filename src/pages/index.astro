---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CallBand from "../components/CallBand.astro";
import { localBusinessSchema } from "../components/LocalBusinessSchema";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLocaleContent, localizedPath, type Locale } from "../site.config";

interface Props {
  locale?: Locale;
}

const locale: Locale = Astro.props.locale ?? "en";
const { business, home, nav } = getLocaleContent(locale);
const path = "/";
---

<BaseLayout title={home.title} description={home.description} locale={locale} schema={localBusinessSchema(path, locale)}>
  <Header locale={locale} currentPath={path} />
  <main>
    <section class="hero">
      <img src={business.heroImage} alt={`Taxi service in ${business.city}`} />
      <div class="hero-content">
        <p class="eyebrow">{home.heroEyebrow}</p>
        <h1>{home.heroTitle}</h1>
        <p>{business.tagline}</p>
        <div class="hero-actions">
          <a class="button" href={`tel:${business.phone}`}>{nav.call} {business.displayPhone}</a>
          <a class="button button-secondary" href={localizedPath(locale, "/service-areas/")}>{home.viewServiceAreas}</a>
        </div>
      </div>
    </section>

    <section class="section intro-grid">
      <div>
        <p class="eyebrow">{home.introEyebrow}</p>
        <h2>{home.introTitle}</h2>
        <p>{business.description}</p>
      </div>
      <div class="quick-card">
        <span>{home.serving}</span>
        <strong>{business.city} + {business.serviceRadiusKm} km</strong>
        <span>{home.available}</span>
        <strong>{home.availableValue}</strong>
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">{home.servicesEyebrow}</p>
        <h2>{home.servicesTitle}</h2>
      </div>
      <div class="card-grid">
        {business.services.map((service) => (
          <article class="service-card">
            <h3>{service}</h3>
            <p>{home.serviceCardText}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section split-band">
      <div>
        <p class="eyebrow">{home.airportEyebrow}</p>
        <h2>{home.airportTitle}</h2>
        <p>{home.airportText}</p>
        <a class="text-link" href={localizedPath(locale, "/airport-taxi/")}>{home.airportLink}</a>
      </div>
      <div>
        <p class="eyebrow">{home.areasEyebrow}</p>
        <h2>{home.areasTitle}</h2>
        <p>{home.areasText}</p>
        <a class="text-link" href={localizedPath(locale, "/service-areas/")}>{home.areasLink}</a>
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">{home.reviewsEyebrow}</p>
        <h2>{home.reviewsTitle}</h2>
      </div>
      <div class="review-grid">
        {business.reviews.map((review) => (
          <figure class="review-card">
            <blockquote>{review.quote}</blockquote>
            <figcaption>{review.author}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <CallBand locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
