---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CallBand from "../components/CallBand.astro";
import { localBusinessSchema } from "../components/LocalBusinessSchema";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLocaleContent, type Locale } from "../site.config";

interface Props {
  locale?: Locale;
}

const locale: Locale = Astro.props.locale ?? "en";
const { business, servicesPage } = getLocaleContent(locale);
const path = "/services/";
---

<BaseLayout title={servicesPage.title} description={servicesPage.description} canonicalPath={path} locale={locale} schema={localBusinessSchema(path, locale)}>
  <Header locale={locale} currentPath={path} />
  <main class="page-main">
    <section class="page-hero">
      <p class="eyebrow">{servicesPage.eyebrow}</p>
      <h1>{servicesPage.heading}</h1>
      <p>{servicesPage.description}</p>
    </section>
    <section class="section">
      <div class="card-grid">
        {business.services.map((service) => (
          <article class="service-card">
            <h2>{service}</h2>
            <p>{servicesPage.cardText}</p>
          </article>
        ))}
      </div>
    </section>
    <CallBand locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
