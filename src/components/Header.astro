---
import { defaultLocale, getLocaleContent, localizedPath, type Locale } from "../site.config";

interface Props {
  locale?: Locale;
  currentPath?: string;
}

const { locale = defaultLocale, currentPath = "/" } = Astro.props;
const { business, nav } = getLocaleContent(locale);
---

<header class="site-header" aria-label="Primary navigation">
  <a class="brand" href={localizedPath(locale, "/")} aria-label={`${business.name} home`}>
    <span class="brand-mark">FT</span>
    <span>{business.name}</span>
  </a>
  <nav>
    <a href={localizedPath(locale, "/services/")}>{nav.services}</a>
    <a href={localizedPath(locale, "/airport-taxi/")}>{nav.airport}</a>
    <a href={localizedPath(locale, "/service-areas/")}>{nav.serviceAreas}</a>
    <span class="language-switch" aria-label="Language selector">
      <a aria-current={locale === "en" ? "page" : undefined} href={localizedPath("en", currentPath)}>EN</a>
      <a aria-current={locale === "ro" ? "page" : undefined} href={localizedPath("ro", currentPath)}>RO</a>
    </span>
    <a class="nav-call" href={`tel:${business.phone}`}>{nav.call} {business.displayPhone}</a>
  </nav>
</header>
