---
import { defaultLocale, getLocaleContent, type Locale } from "../site.config";

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const { business, callBand, nav } = getLocaleContent(locale);
---

<section class="call-band" aria-label={callBand.label}>
  <div>
    <p class="eyebrow">{callBand.eyebrow}</p>
    <h2>{callBand.heading}</h2>
  </div>
  <a class="button button-dark" href={`tel:${business.phone}`}>{nav.call} {business.displayPhone}</a>
</section>
