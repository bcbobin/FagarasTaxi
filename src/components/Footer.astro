---
import { defaultLocale, getLocaleContent, type Locale } from "../site.config";

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const { business, footer } = getLocaleContent(locale);
---

<footer class="site-footer">
  <div>
    <strong>{business.name}</strong>
    <p>{footer.description}</p>
  </div>
  <div>
    <a href={`tel:${business.phone}`}>{business.displayPhone}</a>
    <a href={`mailto:${business.email}`}>{business.email}</a>
    <a href={business.googleMapsUrl}>{footer.maps}</a>
  </div>
</footer>
